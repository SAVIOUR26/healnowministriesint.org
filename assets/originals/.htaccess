# Defense in depth: on hosts where this directory ends up reachable over
# HTTP (e.g. an FTP account scoped to a single web root, so everything is
# flattened into it), never serve these PHP source files directly.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
